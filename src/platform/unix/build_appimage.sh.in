#!/bin/sh
ARCH=$(uname -m)
APPIMAGETOOLURL="https://github.com/AppImage/appimagetool/releases/download/continuous/appimagetool-${ARCH}.AppImage"

# Expected SHA-256 hashes for the pinned continuous-release binaries.
# Update both hashes together whenever bumping appimagetool.
case "${ARCH}" in
  x86_64)  APPIMAGETOOL_SHA256="a6d71e2b6cd66f8e8d16c37ad164658985e0cf5fcaa950c90a482890cb9d13e0" ;;
  aarch64) APPIMAGETOOL_SHA256="1b00524ba8c6b678dc15ef88a5c25ec24def36cdfc7e3abb32ddcd068e8007fe" ;;
  *) echo "Unsupported arch: ${ARCH}" >&2; exit 1 ;;
esac

APP_IMAGE="@SLIC3R_APP_KEY@_ubu64.AppImage"

wget "${APPIMAGETOOLURL}" -O ../appimagetool.AppImage
printf '%s  ../appimagetool.AppImage\n' "${APPIMAGETOOL_SHA256}" | sha256sum --check --status || {
    printf 'appimagetool hash mismatch for %s — update hashes in build_appimage.sh.in\n' "${ARCH}" >&2
    exit 1
}
chmod +x ../appimagetool.AppImage

# Patch AppImage magic bytes so appimagetool runs without FUSE in any
# environment (GitHub ARM runners, Docker containers, CI without fusermount).
sed '0,/AI\x02/{s|AI\x02|\x00\x00\x00|}' -i ../appimagetool.AppImage

sed -i -e 's#/usr#././#g' bin/@SLIC3R_APP_CMD@
mv @SLIC3R_APP_CMD@ AppRun
chmod +x AppRun

cp resources/images/@SLIC3R_APP_KEY@_192px.png @SLIC3R_APP_KEY@.png
for PNG_SIZE in 32 128 192; do
    mkdir -p usr/share/icons/hicolor/${PNG_SIZE}x${PNG_SIZE}/apps
    cp resources/images/@SLIC3R_APP_KEY@_${PNG_SIZE}px.png usr/share/icons/hicolor/${PNG_SIZE}x${PNG_SIZE}/apps/@SLIC3R_APP_KEY@.png
done

cat <<EOF > @SLIC3R_APP_KEY@.desktop
[Desktop Entry]
Name=@SLIC3R_APP_KEY@
GenericName=3D Printing Software
Comment=A cutting-edge, feature-rich slicing software.
Exec=AppRun %U
Icon=@SLIC3R_APP_KEY@
Terminal=false
Type=Application
Categories=Graphics;3DGraphics;Engineering;
MimeType=model/stl;model/3mf;application/vnd.ms-3mfdocument;application/prs.wavefront-obj;application/x-amf;x-scheme-handler/bambustudio;x-scheme-handler/bambustudioopen;
Keywords=3D;Printing;Slicer;slice;3D;printer;convert;gcode;stl;obj;amf;SLA
StartupNotify=false
StartupWMClass=@SLIC3R_APP_CMD@
X-AppImage-Version=@SLIC3R_VERSION@
EOF

../appimagetool.AppImage --appimage-extract-and-run .

mv @SLIC3R_APP_KEY@-${ARCH}.AppImage ${APP_IMAGE}
chmod +x ${APP_IMAGE}
