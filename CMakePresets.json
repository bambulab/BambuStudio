{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 25,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "linux-pixi",
            "displayName": "Linux (pixi env)",
            "description": "Configure against the deps from the active pixi env. Requires `pixi install` and `pixi run setup-libnoise` / `pixi run setup-wxwidgets` first.",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_PREFIX_PATH": "$env{CONDA_PREFIX}",
                "CMAKE_POLICY_VERSION_MINIMUM": "3.5",
                "SLIC3R_GUI": "ON",
                "SLIC3R_GTK": "3",
                "OPENGL_egl_LIBRARY": "$env{CONDA_PREFIX}/lib/libEGL.so",
                "OPENGL_EGL_INCLUDE_DIR": "$env{CONDA_PREFIX}/include",
                "BBL_RELEASE_TO_PUBLIC": "1",
                "BBL_INTERNAL_TESTING": "0"
            },
            "condition": {
                "type": "allOf",
                "conditions": [
                    {
                        "type": "equals",
                        "lhs": "${hostSystemName}",
                        "rhs": "Linux"
                    },
                    {
                        "type": "notEquals",
                        "lhs": "$env{CONDA_PREFIX}",
                        "rhs": ""
                    }
                ]
            }
        },
        {
            "name": "win-pixi-base",
            "hidden": true,
            "description": "Shared cache vars / env for the win-pixi presets (VS 2019 / VS 2022).",
            "binaryDir": "${sourceDir}/build",
            "architecture": { "value": "x64", "strategy": "set" },
            "cacheVariables": {
                "CMAKE_PREFIX_PATH": "$env{CONDA_PREFIX}/Library",
                "CMAKE_POLICY_VERSION_MINIMUM": "3.5",
                "SLIC3R_GUI": "ON",
                "BBL_RELEASE_TO_PUBLIC": "1",
                "BBL_INTERNAL_TESTING": "0",
                "WIN10SDK_PATH": "$env{WIN10SDK_PATH}"
            },
            "environment": {
                "WXWIN": "$env{CONDA_PREFIX}/Library"
            },
            "condition": {
                "type": "allOf",
                "conditions": [
                    {
                        "type": "equals",
                        "lhs": "${hostSystemName}",
                        "rhs": "Windows"
                    },
                    {
                        "type": "notEquals",
                        "lhs": "$env{CONDA_PREFIX}",
                        "rhs": ""
                    }
                ]
            }
        },
        {
            "name": "win-pixi",
            "displayName": "Windows / VS 2022 (pixi env)",
            "description": "Default Windows pixi preset. Requires Visual Studio 2022 + `pixi install` + `pixi run bootstrap`.",
            "inherits": "win-pixi-base",
            "generator": "Visual Studio 17 2022"
        },
        {
            "name": "win-pixi-vs2019",
            "displayName": "Windows / VS 2019 (pixi env)",
            "description": "Windows pixi preset for hosts with only Visual Studio 2019 installed.",
            "inherits": "win-pixi-base",
            "generator": "Visual Studio 16 2019"
        }
    ],
    "buildPresets": [
        {
            "name": "linux-pixi",
            "configurePreset": "linux-pixi",
            "description": "Build with `cmake --build --preset linux-pixi`. CGAL/Boost templates are RAM-heavy; pass `-j N` (e.g. `-j 4`) on hosts with limited memory."
        },
        {
            "name": "win-pixi",
            "configurePreset": "win-pixi",
            "configuration": "Release",
            "description": "Release build for the win-pixi (VS 2022) configure preset."
        },
        {
            "name": "win-pixi-vs2019",
            "configurePreset": "win-pixi-vs2019",
            "configuration": "Release",
            "description": "Release build for the win-pixi-vs2019 configure preset."
        }
    ]
}
