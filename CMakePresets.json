{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 25,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "common",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_POLICY_VERSION_MINIMUM": "3.5"
            }
        },
        {
            "name": "debug",
            "hidden": true,
            "inherits": "common",
            "binaryDir": "${sourceDir}/build/debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "release",
            "hidden": true,
            "inherits": "common",
            "binaryDir": "${sourceDir}/build/release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "linux-pixi",
            "hidden": true,
            "description": "Configure against the deps from the active pixi env. Requires `pixi install` and `pixi run setup-libnoise` / `pixi run setup-wxwidgets` first.",
            "generator": "Unix Makefiles",
            "cacheVariables": {
                "CMAKE_PREFIX_PATH": "$env{CONDA_PREFIX}",
                "CMAKE_C_COMPILER_LAUNCHER": "sccache",
                "CMAKE_CXX_COMPILER_LAUNCHER": "sccache",
                "CMAKE_LINKER_TYPE": "MOLD",
                "SLIC3R_GUI": "ON",
                "SLIC3R_GTK": "3",
                "OPENGL_egl_LIBRARY": "$env{CONDA_PREFIX}/lib/libEGL.so",
                "OPENGL_EGL_INCLUDE_DIR": "$env{CONDA_PREFIX}/include",
                "BBL_RELEASE_TO_PUBLIC": "1",
                "BBL_INTERNAL_TESTING": "0"
            },
            "condition": {
                "type": "allOf",
                "conditions": [
                    {
                        "type": "equals",
                        "lhs": "${hostSystemName}",
                        "rhs": "Linux"
                    },
                    {
                        "type": "notEquals",
                        "lhs": "$env{CONDA_PREFIX}",
                        "rhs": ""
                    }
                ]
            }
        },
        {
            "name": "linux-pixi-debug",
            "displayName": "Linux pixi (Debug)",
            "inherits": ["debug", "linux-pixi"]
        },
        {
            "name": "linux-pixi-release",
            "displayName": "Linux pixi (Release)",
            "inherits": ["release", "linux-pixi"]
        }
    ],
    "buildPresets": [
        {
            "name": "linux-pixi-debug",
            "configurePreset": "linux-pixi-debug",
            "description": "Build Debug. CGAL/Boost templates are RAM-heavy; pass `-j N` (e.g. `-j 4`) on hosts with limited memory."
        },
        {
            "name": "linux-pixi-release",
            "configurePreset": "linux-pixi-release",
            "description": "Build Release. CGAL/Boost templates are RAM-heavy; pass `-j N` (e.g. `-j 4`) on hosts with limited memory."
        }
    ]
}
