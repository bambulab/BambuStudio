# ============================================================================
# BambuStudio Filament Manager E2E - environment variables
# ============================================================================
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored; never commit credentials.

# --- BambuStudio binary ----------------------------------------------------
# Absolute path to the bambu-studio.exe you want to test against.
# Default points at this repo's Release build output.
STUDIO_E2E_BIN=D:\dev_branch\bamboo_slicer_2_github\build_release\src\Release\bambu-studio.exe

# --- WebView2 CDP debug port -----------------------------------------------
# The launcher exports `WEBVIEW2_ADDITIONAL_BROWSER_ARGUMENTS` so that the
# embedded WebView2 chromium starts with `--remote-debugging-port=<port>`.
# Pick any free port; default is 9222.
STUDIO_E2E_CDP_PORT=9222

# --- Optional credentials (only used by tests that need them) --------------
# Most @webview-only specs do not require login; you can leave these blank.
STUDIO_E2E_USER=
STUDIO_E2E_PWD=

# --- Optional printer info (only used by @printer specs) -------------------
STUDIO_E2E_PRINTER_SN=
STUDIO_E2E_PRINTER_IP=

# --- Reporter behaviour ----------------------------------------------------
# Auto-open HTML report after a run? (1 = yes, 0 = no)
STUDIO_E2E_OPEN_REPORT=1
