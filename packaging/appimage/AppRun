#!/bin/bash
# AppImage entry point. Mirrors scripts/pixi/run.sh's runtime env workarounds:
# the binary inside is the same one pixi builds, with the conda-forge / bambulab
# fork stack laid out under usr/ as if it were the active pixi env.

HERE="$(dirname "$(readlink -f "$0")")"
PREFIX="$HERE/usr"

# Resolve bundled .so deps even if the binary's baked-in RPATH points at the
# build host's $CONDA_PREFIX/lib (which doesn't exist on user machines).
export LD_LIBRARY_PATH="$PREFIX/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"

# conda libGLX dispatches to host vendor drivers (e.g. nvidia) and the
# resulting mix can crash MakeCurrent; software GL sidesteps it.
export LIBGL_ALWAYS_SOFTWARE="${LIBGL_ALWAYS_SOFTWARE:-1}"

# `pixi run` would activate the env and set these; AppRun bypasses that, so
# point gtk-3 / gdk-pixbuf / gio at the bundled module/cache files explicitly.
# Without these gtk crashes during GtkStyleProvider init (NULL instance).
export GDK_PIXBUF_MODULE_FILE="$PREFIX/lib/gdk-pixbuf-2.0/2.10.0/loaders.cache"
export GIO_MODULE_DIR="$PREFIX/lib/gio/modules"
export GSETTINGS_SCHEMA_DIR="$PREFIX/share/glib-2.0/schemas"

# Bundled share/ first so the env's Adwaita theme / icons resolve, then host
# share/ as fallback for system overrides.
export XDG_DATA_DIRS="$PREFIX/share:${XDG_DATA_DIRS:-/usr/share:/usr/local/share}"
export GTK_THEME="${GTK_THEME:-Adwaita}"

# conda's libcurl bakes its OPENSSLDIR at build time; outside `pixi run` it
# can't find a CA bundle, breaking https auth. Probe the usual host paths.
for ca in /etc/ssl/certs/ca-certificates.crt \
          /etc/pki/tls/certs/ca-bundle.crt \
          /etc/ssl/cert.pem \
          "$PREFIX/ssl/cacert.pem"; do
    if [[ -f "$ca" ]]; then
        export SSL_CERT_FILE="${SSL_CERT_FILE:-$ca}"
        export CURL_CA_BUNDLE="${CURL_CA_BUNDLE:-$ca}"
        break
    fi
done

exec "$PREFIX/bin/bambu-studio" "$@"
