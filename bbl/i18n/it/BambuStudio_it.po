#~ msgid ""
#~ "Maximum volumetric speed allowed for this filament. Limits the maximum "
#~ "volumetric speed of a print to the minimum of print and filament "
#~ "volumetric speed. Set to zero for no limit."
#~ msgstr ""
#~ "Massima velocità volumetrica consentita per questo filamento. Limita la "
#~ "velocità volumetrica massima di una stampa alla velocità volumetrica "
