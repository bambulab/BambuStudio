msgstr "Hustota vnitřní řídké výplně. 100%%  znamená plnou výplň"

msgid "Fill multiline"
msgstr "Víceřádková výplň"

msgid "Using multiple lines for the infill pattern, if supported by infill pattern."
msgstr "Používá se více linií pro vzor výplně, pokud to vzor výplně umožňuje."

msgid "Sparse infill pattern"
msgstr "Vzor řídké výplně"

msgid "Line pattern for internal sparse infill"
msgstr "Vzor linie pro vnitřní řídkou výplň"

