msgid "TPU is not supported by AMS."
msgstr "TPU není podporováno v AMS."

msgid "AMS does not support 'Bambu Lab PET-CF'."
msgstr "AMS nepodporuje 'Bambu Lab PET-CF'."

msgid "The current filament doesn't support the E3D high-flow nozzle and can't be used."
msgstr "Aktuální filament nepodporuje vysokoprůtokovou trysku E3D a nelze jej použít."

#, c-format, boost-format
msgid "When using %s on the right extruder, it can only be used as support material."
msgstr "Při použití %s v pravém extruderu jej lze použít pouze jako podpůrný materiál."

msgid "The current filament doesn't support the TPU high-flow nozzle and can't be used."
msgstr "Aktuální filament nepodporuje vysokoprůtokovou trysku TPU a nelze jej použít."

msgid "Auto dynamic flow calibration is not supported for TPU filament."
msgstr "Automatická dynamická kalibrace průtoku není podporována pro TPU filament."

msgid "Bambu TPU 85A is not supported for printing with 0.4 mm Standard or High Flow nozzles."
msgstr ""

msgid "When using ABS/ASA/PETG HF on the right extruder, it can only be used as support material."
msgstr ""

msgid "How to feed TPU filament."
msgstr "Jak podávat TPU filament."

msgid "How to feed TPU filament on X2D."
msgstr ""

msgid "Using non-bambu filament may have printing quality issues."
msgstr "Použití jiného než bambu filament může mít za následek sníženou kvalitu tisku."

msgid "Please cold pull before printing TPU to avoid clogging. You may use cold pull maintenance on the printer."
msgstr "Před tiskem TPU prosím proveďte studené vytažení, abyste předešli ucpání. Můžete na tiskárně použít údržbu pomocí studeného vytažení."

msgid "Damp PVA will become flexible and get stuck inside AMS,please take care to dry it before use."
msgstr "Vlhké PVA bude ohebné a může uvíznout uvnitř AMS, proto jej před použitím důkladně vysušte."

msgid "Damp PVA is flexible and may get stuck in extruder. Dry it before use."
msgstr "Vlhké PVA je ohebné a může uvíznout v extruderu. Před použitím jej vysušte."

msgid "PPS-CF is brittle and could break in bended PTFE tube above Toolhead."
msgstr "PPS-CF je křehký a může se zlomit v ohnuté PTFE trubičce nad tiskovou hlavou."

msgid "PPA-CF is brittle and could break in bended PTFE tube above Toolhead."
msgstr "PPA-CF je křehký a může se zlomit v ohnuté PTFE trubičce nad tiskovou hlavou."

msgid "PLA Glow may wear the AMS first stage feeder. Use an external spool instead."
msgstr "PLA Glow může opotřebovat první stupeň podavače v AMS. Použijte místo toho externí cívku."

msgid "Default settings may affect print quality. Adjust as needed for best results."
msgstr "Výchozí nastavení může ovlivnit kvalitu tisku. Upravte podle potřeby pro dosažení nejlepších výsledků."

#, c-format, boost-format
msgid "%s has a risk of nozzle clogging when using 0.4mm high-flow nozzles. Use with caution."
msgstr "%s představuje riziko ucpání trysky při použití 0,4mm high-flow trysek. Používejte opatrně."

#, c-format, boost-format
msgid "%s filaments are hard and brittle and could break in AMS, and there is also a risk of nozzle clogging when using 0.4mm high-flow nozzles. Use with caution."
msgstr "%s filamenty jsou tvrdé a křehké, mohou se zlomit v AMS a existuje také riziko ucpání trysky při použití 0,4mm high-flow trysek. Používejte opatrně."

#, c-format, boost-format
msgid "%s has a risk of nozzle clogging when using 0.4, 0.6, 0.8mm high-flow nozzles. Use with caution."
msgstr "%s představuje riziko ucpání trysky při použití 0,4, 0,6 a 0,8mm high-flow trysek. Používejte opatrně."

