<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX 4+ MSI manifest for Bambu Studio.

  Built via scripts/pixi/windows/dist.ps1 with:
      wix build BambuStudio.wxs -arch x64 -d Payload=<staged-tree> -d Version=N.N.N.N -o ...

  $(Payload)  must point to a directory whose contents are the installed
              tree root (the cmake install output: bambu-studio.exe + all
              DLLs + resources/). Files Include="**" bulk-imports it.

  $(Version)  must be a 4-part numeric version (Windows Installer rule).
              version.inc ships "02.06.01.55" which fits as-is.

  UpgradeCode is the stable identity of the Bambu Studio MSI product
  family. NEVER change it across releases — Windows Installer uses it
  to find and uninstall older versions during MajorUpgrade.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="Bambu Studio"
           Manufacturer="Bambu Lab"
           Version="$(Version)"
           UpgradeCode="7AA17F3C-249E-4A31-B663-5FBFD839DD76"
           Scope="perMachine"
           Compressed="yes">

    <SummaryInformation Description="Bambu Studio — 3D printer slicer (pixi build)" />
    <MediaTemplate EmbedCab="yes" />
    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Bambu Studio" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="Bambu Studio" />
    </StandardDirectory>

    <ComponentGroup Id="BambuStudioFiles" Directory="INSTALLFOLDER">
      <Files Include="$(Payload)\**" />
    </ComponentGroup>

    <Component Id="ApplicationShortcut" Directory="ApplicationProgramsFolder" Guid="*">
      <Shortcut Id="StartMenuShortcut"
                Name="Bambu Studio"
                Target="[INSTALLFOLDER]bambu-studio.exe"
                WorkingDirectory="INSTALLFOLDER" />
      <RemoveFolder Id="CleanupShortcutFolder" Directory="ApplicationProgramsFolder" On="uninstall" />
      <RegistryValue Root="HKCU"
                     Key="Software\BambuLab\BambuStudio"
                     Name="installed"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
    </Component>

    <Feature Id="Main" Title="Bambu Studio" Level="1">
      <ComponentGroupRef Id="BambuStudioFiles" />
      <ComponentRef Id="ApplicationShortcut" />
    </Feature>

  </Package>
</Wix>
