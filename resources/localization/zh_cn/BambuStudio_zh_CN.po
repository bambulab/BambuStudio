msgid "Position X"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2820
msgid "X coordinate of the left front corner of a wipe tower"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2827
msgid "Position Y"
msgstr ""

