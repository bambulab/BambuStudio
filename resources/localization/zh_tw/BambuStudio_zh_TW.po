msgstr "°"

#: src/libslic3r/PrintConfig.cpp:493
msgid "Bridges fan speed"
msgstr "橋風扇速度"

#: src/libslic3r/PrintConfig.cpp:494
msgid "This fan speed is enforced during all bridges and overhangs."
msgstr "此項爲在列印所有橋和懸垂部位時的風扇速度。"

#: src/libslic3r/PrintConfig.cpp:495 src/libslic3r/PrintConfig.cpp:1177
#: src/libslic3r/PrintConfig.cpp:1685 src/libslic3r/PrintConfig.cpp:1880
#: src/libslic3r/PrintConfig.cpp:1945 src/libslic3r/PrintConfig.cpp:1954
