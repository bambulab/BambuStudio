msgstr ""

#: src/libslic3r/PrintConfig.cpp:2387
msgid "tree"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2392
msgid "XY separation between an object and its support"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2394
msgid ""
"XY separation between an object and its support. If expressed as percentage "
"(for example 50%), it will be calculated over external perimeter width."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2405
msgid "Pattern angle"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2407
msgid ""
"Use this setting to rotate the support material pattern on the horizontal "
"plane."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2416
msgid "On build plate only"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2418 src/libslic3r/PrintConfig.cpp:3530
msgid ""
"Only create support if it lies on a build plate. Don't create support on a "
"print."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2426
msgid "Top Z distance"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2428
msgid ""
"The vertical distance between object and support material interface. It will "
"be align to layer height if wipe tower is enabled in multi-material project."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2436
msgid "0 (soluble)"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2437
msgid "0.1 (semi-detachable)"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2438
msgid "0.2 (detachable)"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2447
msgid "Bottom contact Z distance"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2449
msgid ""
"The vertical distance between the object top surface and the support "
"material interface. If set to zero, support_top_z_distance will be used for "
"both top and bottom contact Z distances."
msgstr ""

#. TRN To be shown in Print Settings "Bottom contact Z distance". Have to be as short as possible
#. TRN To be shown in Print Settings "Bottom interface layers". Have to be as short as possible
#: src/libslic3r/PrintConfig.cpp:2458 src/libslic3r/PrintConfig.cpp:2559
msgid "Same as top"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2466
msgid "Enforce support for the first"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2468
msgid ""
"Generate support material for the specified number of layers counting from "
"bottom, regardless of whether normal support material is enabled or not and "
"regardless of any angle threshold. This is useful for getting more adhesion "
"of objects having a very thin or poor footprint on the build plate."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2473
msgid "Enforce support for the first n layers"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2482
msgid ""
"The extruder to use when printing support material, raft and skirt (1+, 0 to "
"use the current extruder to minimize tool changes)."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2492
msgid ""
"Set this to a non-zero value to set a manual extrusion width for support "
"material. If left zero, default extrusion width will be used if set, "
"otherwise nozzle diameter will be used. If expressed as percentage (for "
"example 90%) it will be computed over layer height."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2504
msgid ""
"Set this to a non-zero value to set a manual extrusion width for support "
"transition. If left zero, default extrusion width will be used if set, "
"otherwise nozzle diameter will be used. If expressed as percentage (for "
"example 90%) it will be computed over layer height."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2513
msgid "Interface loops"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2515
msgid ""
"Cover the top contact layer of the supports with loops. Disabled by default."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2521 src/libslic3r/PrintConfig.cpp:2594
msgid "Support interface"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2523
msgid ""
"The extruder to use when printing support material interface (1+, 0 to use "
"the current extruder to minimize tool changes). This affects raft too."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2532
msgid "Top interface layers"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2534
msgid ""
"Number of interface layers to insert between the object(s) and support "
"material."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2541
msgid "0 (off)"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2542
msgid "1 (light)"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2543
msgid "2 (default)"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2544
msgid "3 (heavy)"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2550
msgid "Bottom interface layers"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2552
msgid ""
"Number of interface layers to insert between the object(s) and support "
"material. Set to -1 to use support_interface_top_layers"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2565
msgid "Closing radius"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2567
msgid ""
"For snug supports, the support regions will be merged using morphological "
"closing operation. Gaps smaller than the closing radius will be filled in."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2575
msgid "Top interface spacing"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2577
msgid "Spacing between interface lines. Set zero to get a solid interface."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2585
msgid "Bottom interface spacing"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2587
msgid ""
"Spacing between bottom interface lines. Set zero to get a solid interface."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2596
msgid ""
"Speed for printing support material interface layers. If expressed as "
"percentage (for example 50%) it will be calculated over support material "
"speed."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2607
msgid ""
"Speed for printing support transition layers in which support infill "
"direction is changed.If expressed as percentage (for example 50%) it will be "
"calculated over support material speed."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2616
msgid "Base pattern"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2618
msgid "Pattern used to generate support material."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2624
msgid "Rectilinear grid"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2630
msgid "Interface pattern"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2632
msgid ""
"Pattern used to generate support material interface. Default pattern for non-"
"soluble support interface is Rectilinear, while default pattern for soluble "
"support interface is Concentric."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2646
msgid "Base pattern spacing"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2648
msgid "Spacing between support material lines."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2657
msgid "Speed for printing support material."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2664
msgid "Style"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2666
msgid ""
"Style and shape of the support towers. Projecting the supports into a "
"regular grid will create more stable supports, while snug support towers "
"will save material and reduce object scarring."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2673
msgid "Snug"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2679
msgid "Independent support layer height"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2681
msgid ""
"Support layer uses layer height independent with object layer. This is to "
"support custom support gap,but may cause extra extruder switches if support "
"is specified as different extruder with object."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2688
msgid "Threshold angle"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2690
msgid ""
"Support material will not be generated for overhangs whose slope angle (90° "
"= vertical) is above the given threshold. In other words, this value "
"represent the most horizontal slope (measured from the horizontal plane) "
"that you can print without support material. Set to zero for automatic "
"detection (recommended)."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2703
msgid "With sheath around the support"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2705
msgid ""
"Add a sheath (a single perimeter line) around the base support. This makes "
"the support more reliable, but also more difficult to remove."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2713
msgid "Tree support branch angle"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2715
msgid ""
"This setting determines the maximum overhang angle that t he branches of "
"tree support allowed to make.If the angle is increased, the branches can be "
"printed more horizontally, allowing them to reach farther."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2726
msgid ""
"This setting determines the distance between two adjacent branches where the "
"branches touch the build plate.\n"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2736
msgid ""
"This setting allows you to adjust the width of tree support's branches. The "
"width specified here will bethe width at the top of the tree's branches. The "
"very tip of branch will be thinner and towards the bottomit gradually "
"becomes wider as per the Tree Support Branch Diameter Angle Setting."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2746
msgid "Tree support branch diameter angle"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2748
msgid ""
"The branches of tree support are wider towards the bottom than they are at "
"the top. This ensures thatthe branches remain stable no matter how tall the "
"support gets. With this setting, you can control therate at which the "
"support gets wider."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2761
msgid ""
"A major disadvantage of tree support is that it takes a long time to slice "
"when it is activated. Most of thecalculations necessary for tree support are "
"for the branches of the tree to avoid colliding with mesh.This setting "
"determines the accuracy of these collision avoidance calculations. "
"Increasing this resolution(lower accuracy) will save a lot of time "
"calculating, but will also make the support appear jagged when it'snear the "
"mesh."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2774
msgid "Tree support wall loops"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2776
msgid "This setting specify the count of walls around support."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2782
msgid "Tree support with infill"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2784
msgid ""
"This setting specifies whether to add infill inside large hollows of tree "
"support."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2790
msgid ""
"Nozzle temperature for layers after the first one. Set this to zero to "
"disable temperature control commands in the output G-code."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2793
msgid "Nozzle temperature"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2799
msgid "Thick bridges"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2801
msgid ""
"If enabled, bridges are more reliable, can bridge longer distances, but may "
"look worse. If disabled, bridges look better but are reliable just for "
"shorter bridged distances."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2807
msgid "Detect thin wall"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2809
msgid ""
"Detect single-width walls (parts where two extrusions don't fit and we need "
"to collapse them into a single trace)."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2817
msgid ""
"This custom code is inserted before every toolchange. Placeholder variables "
"for all BambuStudio settings as well as {toolchange_z}, {previous_extruder} "
"and {next_extruder} can be used. When a tool-changing command which changes "
"to the correct extruder is included (such as T{next_extruder}), BambuStudio "
"will emit no other such command. It is therefore possible to script custom "
"behaviour both before and after the toolchange."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2829 src/libslic3r/PrintConfig.cpp:2842
msgid "Top surface"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2831
msgid ""
"Set this to a non-zero value to set a manual extrusion width for infill for "
"top surfaces. You may want to use thinner extrudates to fill all narrow "
"regions and get a smoother finish. If left zero, default extrusion width "
"will be used if set, otherwise nozzle diameter will be used. If expressed as "
"percentage (for example 90%) it will be computed over layer height."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2844
msgid ""
"Speed for printing top solid layers (it only applies to the uppermost "
"external layers and not to their internal solid layers). You may want to "
"slow down this to get a nicer surface finish. This can be expressed as a "
"percentage (for example: 80%) over the solid infill speed above. Set to zero "
"for auto."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2856
msgid "Top shell layers"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2858
msgid "Number of solid layers to generate on top surfaces."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2859
msgid "Top solid layers"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2864
msgid "Top shell thickness"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2866
msgid ""
"The number of top solid layers is increased above top_shell_layers if "
"necessary to satisfy minimum thickness of top shell. This is useful to "
"prevent pillowing effect when printing with variable layer height."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2869
msgid "Minimum top shell thickness"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2876
msgid "Speed for travel moves (jumps between distant extrusion points)."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2884
msgid "Z travel"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2885
msgid ""
"Speed for movements along the Z axis.\n"
"When set to zero, the value is ignored and regular travel speed is used "
"instead."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2893
msgid "Wipe while retracting"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2894
msgid ""
"This flag will move the nozzle while retracting to minimize the possible "
"blob on leaky extruders."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2902
msgid "Wipe Distance"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2903
msgid ""
"Discribe how long the nozzle will move while retracting to minimize blob."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2911
msgid ""
"Multi material printers may need to prime or purge extruders on tool "
"changes. Extrude the excess material into the wipe tower."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2918
msgid "Purging volumes - load/unload volumes"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2919
msgid ""
"This vector saves required volumes to change from/to each tool used on the "
"wipe tower. These values are used to simplify creation of the full purging "
"volumes below."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2927
msgid "Purging volumes - matrix"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2928
msgid ""
"This matrix describes volumes (in cubic milimetres) required to purge the "
"new filament on the wipe tower for any given pair of tools."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2939
msgid "Wipe volume"
