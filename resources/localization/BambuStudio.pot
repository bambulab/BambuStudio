msgstr ""

#: src/libslic3r/PrintConfig.cpp:2391
msgid "normal"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2392
msgid "tree"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2397
msgid "XY separation between an object and its support"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2399
msgid ""
"XY separation between an object and its support. If expressed as percentage "
"(for example 50%), it will be calculated over external perimeter width."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2410
msgid "Pattern angle"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2412
msgid ""
"Use this setting to rotate the support material pattern on the horizontal "
"plane."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2421
msgid "On build plate only"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2423 src/libslic3r/PrintConfig.cpp:3535
msgid ""
"Only create support if it lies on a build plate. Don't create support on a "
"print."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2431
msgid "Top Z distance"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2433
msgid ""
"The vertical distance between object and support material interface. It will "
"be align to layer height if wipe tower is enabled in multi-material project."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2441
msgid "0 (soluble)"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2442
msgid "0.1 (semi-detachable)"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2443
msgid "0.2 (detachable)"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2452
msgid "Bottom contact Z distance"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2454
msgid ""
"The vertical distance between the object top surface and the support "
"material interface. If set to zero, support_top_z_distance will be used for "
"both top and bottom contact Z distances."
msgstr ""

#. TRN To be shown in Print Settings "Bottom contact Z distance". Have to be as short as possible
#. TRN To be shown in Print Settings "Bottom interface layers". Have to be as short as possible
#: src/libslic3r/PrintConfig.cpp:2463 src/libslic3r/PrintConfig.cpp:2564
msgid "Same as top"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2471
msgid "Enforce support for the first"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2473
msgid ""
"Generate support material for the specified number of layers counting from "
"bottom, regardless of whether normal support material is enabled or not and "
"regardless of any angle threshold. This is useful for getting more adhesion "
"of objects having a very thin or poor footprint on the build plate."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2478
msgid "Enforce support for the first n layers"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2487
msgid ""
"The extruder to use when printing support material, raft and skirt (1+, 0 to "
"use the current extruder to minimize tool changes)."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2497
msgid ""
"Set this to a non-zero value to set a manual extrusion width for support "
"material. If left zero, default extrusion width will be used if set, "
"otherwise nozzle diameter will be used. If expressed as percentage (for "
"example 90%) it will be computed over layer height."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2509
msgid ""
"Set this to a non-zero value to set a manual extrusion width for support "
"transition. If left zero, default extrusion width will be used if set, "
"otherwise nozzle diameter will be used. If expressed as percentage (for "
"example 90%) it will be computed over layer height."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2518
msgid "Interface loops"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2520
msgid ""
"Cover the top contact layer of the supports with loops. Disabled by default."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2528
msgid ""
"The extruder to use when printing support material interface (1+, 0 to use "
"the current extruder to minimize tool changes). This affects raft too."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2537
msgid "Top interface layers"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2539
msgid ""
"Number of interface layers to insert between the object(s) and support "
"material."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2546
msgid "0 (off)"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2547
msgid "1 (light)"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2548
msgid "2 (default)"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2549
msgid "3 (heavy)"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2555
msgid "Bottom interface layers"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2557
msgid ""
"Number of interface layers to insert between the object(s) and support "
"material. Set to -1 to use support_interface_top_layers"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2570
msgid "Closing radius"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2572
msgid ""
"For snug supports, the support regions will be merged using morphological "
"closing operation. Gaps smaller than the closing radius will be filled in."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2580
msgid "Top interface spacing"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2582
msgid "Spacing between interface lines. Set zero to get a solid interface."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2590
msgid "Bottom interface spacing"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2592
msgid ""
"Spacing between bottom interface lines. Set zero to get a solid interface."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2601
msgid ""
"Speed for printing support material interface layers. If expressed as "
"percentage (for example 50%) it will be calculated over support material "
"speed."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2612
msgid ""
"Speed for printing support transition layers in which support infill "
"direction is changed.If expressed as percentage (for example 50%) it will be "
"calculated over support material speed."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2621
msgid "Base pattern"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2623
msgid "Pattern used to generate support material."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2629
msgid "Rectilinear grid"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2635
msgid "Interface pattern"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2637
msgid ""
"Pattern used to generate support material interface. Default pattern for non-"
"soluble support interface is Rectilinear, while default pattern for soluble "
"support interface is Concentric."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2651
msgid "Base pattern spacing"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2653
msgid "Spacing between support material lines."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2662
msgid "Speed for printing support material."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2669
msgid "Style"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2671
msgid ""
"Style and shape of the support towers. Projecting the supports into a "
"regular grid will create more stable supports, while snug support towers "
"will save material and reduce object scarring."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2678
msgid "Snug"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2684
msgid "Independent support layer height"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2686
msgid ""
"Support layer uses layer height independent with object layer. This is to "
"support custom support gap,but may cause extra extruder switches if support "
"is specified as different extruder with object."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2693
msgid "Threshold angle"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2695
msgid ""
"Support material will not be generated for overhangs whose slope angle (90° "
"= vertical) is above the given threshold. In other words, this value "
"represent the most horizontal slope (measured from the horizontal plane) "
"that you can print without support material. Set to zero for automatic "
"detection (recommended)."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2708
msgid "With sheath around the support"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2710
msgid ""
"Add a sheath (a single perimeter line) around the base support. This makes "
"the support more reliable, but also more difficult to remove."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2718
msgid "Tree support branch angle"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2720
msgid ""
"This setting determines the maximum overhang angle that t he branches of "
"tree support allowed to make.If the angle is increased, the branches can be "
"printed more horizontally, allowing them to reach farther."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2731
msgid ""
"This setting determines the distance between two adjacent branches where the "
"branches touch the build plate.\n"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2741
msgid ""
"This setting allows you to adjust the width of tree support's branches. The "
"width specified here will bethe width at the top of the tree's branches. The "
"very tip of branch will be thinner and towards the bottomit gradually "
"becomes wider as per the Tree Support Branch Diameter Angle Setting."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2751
msgid "Tree support branch diameter angle"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2753
msgid ""
"The branches of tree support are wider towards the bottom than they are at "
"the top. This ensures thatthe branches remain stable no matter how tall the "
"support gets. With this setting, you can control therate at which the "
"support gets wider."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2766
msgid ""
"A major disadvantage of tree support is that it takes a long time to slice "
"when it is activated. Most of thecalculations necessary for tree support are "
"for the branches of the tree to avoid colliding with mesh.This setting "
"determines the accuracy of these collision avoidance calculations. "
"Increasing this resolution(lower accuracy) will save a lot of time "
"calculating, but will also make the support appear jagged when it'snear the "
"mesh."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2779
msgid "Tree support wall loops"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2781
msgid "This setting specify the count of walls around support."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2787
msgid "Tree support with infill"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2789
msgid ""
"This setting specifies whether to add infill inside large hollows of tree "
"support."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2795
msgid ""
"Nozzle temperature for layers after the first one. Set this to zero to "
"disable temperature control commands in the output G-code."
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2798
msgid "Nozzle temperature"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2804
msgid "Thick bridges"
msgstr ""

#: src/libslic3r/PrintConfig.cpp:2806
msgid ""
"If enabled, bridges are more reliable, can bridge longer distances, but may "
